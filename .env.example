# Copy this file to `.env.local` and fill in values from the Firebase console:
#   https://console.firebase.google.com/ → Project Settings → General → Your apps → Web app

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: override the default public site URL used in share links.
VITE_PUBLIC_URL=http://localhost:5173
