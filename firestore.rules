rules_version = '2';

// Gifted Firestore security rules.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function isAdmin() {
      return isSignedIn()
        && request.auth.token.email != null
        && request.auth.token.email.lower() in [
          'rwoodman01@gmail.com',
          'michael.whitaker1490@gmail.com',
        ];
    }

    function selfUpdatableFields() {
      return [
        'displayName', 'email', 'photoURL', 'bio', 'location',
        'profilePhotoPath', 'portfolioPhotos',
        'talentsOffered', 'servicesNeeded', 'proofPhotos',
        'welcomeSeen',
        'subscriptionActive', 'paidAt',
        'bgCheckConfirmed', 'bgCheckDate',
        'standardsAgreed', 'standardsAgreedAt',
        'profileComplete',
        'referredBy',
        'status', 'applicationSubmittedAt',
        'updatedAt',
        // Admin-only: opt this account into browse/swipe for testing.
        'showInBrowse',
      ];
    }

    /** Approved members visible to non-admin signed-in users (browse, profiles). */
    function memberVisibleInCommunity() {
      return resource.data.status == 'approved'
        && (!('role' in resource.data) || resource.data.role != 'admin'
            || resource.data.showInBrowse == true);
    }

    function isTradeCompletionBump(uid) {
      let a = request.resource.data;
      let b = resource.data;
      return a.diff(b).affectedKeys().hasOnly(['tradeCount', 'connections', 'badges', 'updatedAt'])
        && a.tradeCount == b.tradeCount + 1
        && a.connections.size() == b.connections.size() + 1
        && a.connections.hasAll(b.connections)
        && a.badges.hasAll(b.badges)
        && (
          (request.auth.uid != uid
            && !b.connections.hasAny([request.auth.uid])
            && a.connections.hasAny([request.auth.uid]))
          || request.auth.uid == uid
        );
    }

    function dealParticipants(dealId) {
      return get(/databases/$(database)/documents/deals/$(dealId)).data.participantIds;
    }

    function isParticipantOfDeal(dealId) {
      return isSignedIn()
        && request.auth.uid in dealParticipants(dealId);
    }

    match /users/{uid} {
      allow read: if isSelf(uid)
        || isAdmin()
        || (isSignedIn() && memberVisibleInCommunity());

      allow create: if isSelf(uid)
        && request.resource.data.status == 'unpaid'
        && request.resource.data.subscriptionActive == false
        && request.resource.data.tradeCount == 0
        && request.resource.data.badges.size() == 0;

      allow update: if isAdmin()
        || (
          isSelf(uid)
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(selfUpdatableFields())
          && (
            !('portfolioPhotos' in request.resource.data)
            || request.resource.data.portfolioPhotos.size() <= 9
          )
          && (
            request.resource.data.status == resource.data.status
            || (
              resource.data.status == 'unpaid'
              && request.resource.data.status == 'pending'
            )
          )
          && (
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['showInBrowse'])
            || resource.data.role == 'admin'
            || isAdmin()
          )
        )
        || isTradeCompletionBump(uid);

      allow delete: if isAdmin();

      match /reviewQueue/{dealId} {
        allow read: if isSelf(uid)
          || isAdmin()
          || (isSignedIn()
              && get(/databases/$(database)/documents/users/$(uid)).data.status == 'approved');

        allow create, update: if isParticipantOfDeal(dealId)
          && uid in dealParticipants(dealId)
          && request.resource.data.dealId == dealId;

        allow delete: if isSelf(uid);
      }

      match /notifications/{nid} {
        allow read: if isSelf(uid) || isAdmin();
        allow create: if isSignedIn()
          && request.resource.data.recipientId == uid
          && request.resource.data.fromUid == request.auth.uid
          && request.resource.data.type is string
          && request.resource.data.message is string
          && request.resource.data.link is string
          && request.resource.data.readAt == null;
        allow update: if isSelf(uid)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readAt']);
        allow delete: if isSelf(uid) || isAdmin();
      }

      match /swipes/{targetUid} {
        allow read: if isSelf(uid) || isAdmin();
        allow create, update: if isSelf(uid)
          && targetUid != uid
          && request.resource.data.targetUid == targetUid
          && request.resource.data.direction in ['left', 'right']
          && request.resource.data.source in ['swipe', 'button'];
        allow delete: if isSelf(uid) || isAdmin();
      }

      match /fcmTokens/{tokenId} {
        // Only the owner can read or write their own FCM push tokens.
        // The backend (Cloud Functions admin SDK) bypasses these rules.
        allow read, write: if isSelf(uid);
      }

      match /giftedScoreMeta/{docId} {
        // Private, per-user Gifted Score breakdown (owner-only).
        // Written by Cloud Functions via Admin SDK.
        allow read: if isSelf(uid) || isAdmin();
        allow write: if false;
      }
    }

    match /deals/{dealId} {
      function isParticipant() {
        return isSignedIn()
          && request.auth.uid in resource.data.participantIds;
      }
      function willBeParticipant() {
        return isSignedIn()
          && request.auth.uid in request.resource.data.participantIds
          && request.resource.data.participantIds.size() == 2
          && request.resource.data.participantIds
               .hasAll([request.resource.data.initiatorId,
                        request.resource.data.receiverId]);
      }

      allow read: if isParticipant() || isAdmin();
      allow create: if willBeParticipant()
        && request.resource.data.initiatorId == request.auth.uid
        && request.resource.data.status in ['requested', 'proposed'];
      allow update: if isParticipant() || isAdmin();
      allow delete: if isAdmin();

      match /messages/{msgId} {
        allow read: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/deals/$(dealId)).data.participantIds
          || isAdmin();
        allow create: if isSignedIn()
          && request.resource.data.senderId == request.auth.uid
          && request.auth.uid in get(/databases/$(database)/documents/deals/$(dealId)).data.participantIds;
        allow update, delete: if false;
      }

      match /reviews/{reviewerId} {
        allow read: if isAdmin()
          || (isSignedIn()
              && request.auth.uid in get(/databases/$(database)/documents/deals/$(dealId)).data.participantIds);
        allow create: if isSelf(reviewerId)
          && request.auth.uid in get(/databases/$(database)/documents/deals/$(dealId)).data.participantIds;
        allow update, delete: if false;
      }
    }

    match /reviews/{reviewId} {
      function dealD() {
        return get(/databases/$(database)/documents/deals/$(resource.data.dealId)).data;
      }
      function dealDReq() {
        return get(/databases/$(database)/documents/deals/$(request.resource.data.dealId)).data;
      }

      allow read: if isAdmin()
        || (isSignedIn() && resource.data.reviewerId == request.auth.uid)
        || (isSignedIn()
            && resource.data.visibleAt != null
            && (!('suppressed' in resource.data) || resource.data.suppressed == false)
            && (!('moderationStatus' in resource.data)
                || resource.data.moderationStatus != 'removed'));

      allow create: if isSignedIn()
        && request.resource.data.reviewerId == request.auth.uid
        && request.resource.data.dealId is string
        && request.resource.data.revieweeId is string
        && request.resource.data.starRating is int
        && request.resource.data.starRating >= 1
        && request.resource.data.starRating <= 5
        && request.resource.data.showedUp is bool
        && request.resource.data.wouldTradeAgain is bool
        && request.resource.data.writtenReview is string
        && request.resource.data.writtenReview.size() <= 600
        && request.resource.data.skillTags is list
        && request.resource.data.skillTags.size() <= 3
        && request.resource.data.flags is list
        && request.resource.data.flags.size() == 0
        && request.resource.data.flagged == false
        && request.resource.data.suppressed == false
        && (!('visibleAt' in request.resource.data)
            || request.resource.data.visibleAt == null)
        && request.resource.data.exchangeOfferInitiator is string
        && request.resource.data.exchangeOfferReceiver is string
        && request.resource.data.exchangeOfferInitiator.size() <= 120
        && request.resource.data.exchangeOfferReceiver.size() <= 120
        && request.auth.uid in dealDReq().participantIds
        && (
          request.auth.uid == dealDReq().initiatorId
            && request.resource.data.revieweeId == dealDReq().receiverId
          || request.auth.uid == dealDReq().receiverId
            && request.resource.data.revieweeId == dealDReq().initiatorId
        );

      allow update: if isAdmin()
        || (
          isSignedIn()
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['flags', 'flagged', 'suppressed', 'updatedAt'])
          && resource.data.reviewerId != request.auth.uid
          && request.resource.data.flags.hasAll(
               'flags' in resource.data ? resource.data.flags : [])
          && (
            (!('flags' in resource.data) && request.resource.data.flags.size() == 1)
            || ('flags' in resource.data
              && request.resource.data.flags.size() == resource.data.flags.size() + 1)
          )
          && request.resource.data.flags.hasAny([request.auth.uid])
          && (!('flags' in resource.data) || !resource.data.flags.hasAny([request.auth.uid]))
        )
        || (
          isSignedIn()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['visibleAt'])
          && request.auth.uid in dealD().participantIds
          && (!('visibleAt' in resource.data) || resource.data.visibleAt == null)
        );

      allow delete: if isAdmin();
    }

    match /matches/{matchId} {
      allow read: if isSignedIn()
        && request.auth.uid in resource.data.participantIds;
      allow create, update, delete: if isAdmin();
    }

    match /posts/{postId} {
      function isApprovedTrader(uid) {
        let u = get(/databases/$(database)/documents/users/$(uid)).data;
        return u.status == 'approved' && u.tradeCount >= 1;
      }

      function validNewPost(d) {
        return d.type in ['offering', 'looking_for', 'community']
          && d.availability in ['this_week', 'this_month', 'flexible']
          && d.status == 'active'
          && d.flagCount == 0
          && d.interestCount == 0
          && d.what is string && d.what.size() > 0 && d.what.size() <= 80
          && d.exchange is string && d.exchange.size() <= 80
          && d.details is string && d.details.size() <= 300
          && d.location is string && d.location.size() > 0 && d.location.size() <= 80
          && d.locationKey is string && d.locationKey.size() > 0
          && d.authorDisplayName is string
          && d.authorPhotoURL is string;
      }

      // Anyone signed in can read active posts; author and admin can also see
      // their own hidden posts (for the moderation review flow).
      allow read: if isSignedIn()
        && (
          resource.data.status == 'active'
          || request.auth.uid == resource.data.authorId
          || isAdmin()
        );

      allow create: if isSignedIn()
        && isApprovedTrader(request.auth.uid)
        && request.resource.data.authorId == request.auth.uid
        && validNewPost(request.resource.data);

      // Author may not edit posts directly (keeps the wall honest); admin can
      // flip status for moderation. Cloud Functions use the admin SDK and
      // bypass these rules to maintain flagCount/interestCount.
      allow update: if isAdmin();

      allow delete: if isSignedIn()
        && (request.auth.uid == resource.data.authorId || isAdmin());

      match /interests/{uid} {
        // Author and the interested user can read; admin too.
        allow read: if isSignedIn()
          && (
            request.auth.uid == uid
            || request.auth.uid == get(/databases/$(database)/documents/posts/$(postId)).data.authorId
            || isAdmin()
          );
        allow create, update: if isSignedIn()
          && request.auth.uid == uid
          && request.resource.data.uid == uid;
        allow delete: if isSelf(uid) || isAdmin();
      }

      match /flags/{uid} {
        allow read: if isAdmin();
        allow create: if isSignedIn()
          && request.auth.uid == uid
          && request.resource.data.uid == uid;
        allow update, delete: if false;
      }
    }
  }
}
