rules_version = '2';

// Ungig Firestore security rules.
//
// Guiding principles:
//   - A signed-in user can always read and update their own user doc
//     (but cannot set their own `status`, `role`, `tradeCount`, or `badges`).
//   - Approved members are visible to every other signed-in user.
//   - Deals and their messages/reviews are only visible to participants.
//   - Admins (email allowlist) have broad read + moderation access.
//
// NOTE: the ADMIN_EMAILS list below is duplicated from src/lib/constants.js.
// In phase 2 we'll replace both with Firebase Auth custom claims.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function isAdmin() {
      return isSignedIn()
        && request.auth.token.email != null
        && request.auth.token.email.lower() in [
          // Keep in sync with src/lib/constants.js ADMIN_EMAILS.
          'rwoodman01@gmail.com',
          'michael.whitaker1490@gmail.com',
        ];
    }

    // Fields members can change on themselves. `status`, `role`, `badges`,
    // `tradeCount`, and `connections` are server/admin-controlled.
    function selfUpdatableFields() {
      return [
        'displayName', 'email', 'photoURL', 'bio', 'location',
        'talentsOffered', 'servicesNeeded', 'proofPhotos',
        'welcomeSeen',
        'subscriptionActive', 'paidAt',
        'bgCheckConfirmed', 'bgCheckDate',
        'standardsAgreed', 'standardsAgreedAt',
        'profileComplete',
        'referredBy',
        // `status` flips to 'pending' when the application is submitted.
        // Anything beyond 'pending' (approved/rejected) is admin-only —
        // we keep that control in the update condition below.
        'status', 'applicationSubmittedAt',
        'updatedAt',
      ];
    }

    match /users/{uid} {
      allow read: if isSelf(uid)
        || isAdmin()
        || (isSignedIn() && resource.data.status == 'approved');

      allow create: if isSelf(uid)
        && request.resource.data.status == 'unpaid'
        && request.resource.data.subscriptionActive == false
        && request.resource.data.tradeCount == 0
        && request.resource.data.badges.size() == 0;

      // Self-update: whitelist of fields + members can only move their own
      // `status` from 'unpaid' -> 'pending' (the application submission).
      // Admins can change status freely.
      allow update: if isAdmin()
        || (
          isSelf(uid)
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(selfUpdatableFields())
          && (
            request.resource.data.status == resource.data.status
            || (
              resource.data.status == 'unpaid'
              && request.resource.data.status == 'pending'
            )
          )
        );

      allow delete: if isAdmin();
    }

    match /deals/{dealId} {
      function isParticipant() {
        return isSignedIn()
          && request.auth.uid in resource.data.participantIds;
      }
      function willBeParticipant() {
        return isSignedIn()
          && request.auth.uid in request.resource.data.participantIds
          && request.resource.data.participantIds.size() == 2
          && request.resource.data.participantIds
               .hasAll([request.resource.data.initiatorId,
                        request.resource.data.receiverId]);
      }

      allow read: if isParticipant() || isAdmin();
      allow create: if willBeParticipant()
        && request.resource.data.initiatorId == request.auth.uid
        && request.resource.data.status == 'requested';
      allow update: if isParticipant() || isAdmin();
      allow delete: if isAdmin();

      match /messages/{msgId} {
        allow read: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/deals/$(dealId)).data.participantIds
          || isAdmin();
        allow create: if isSignedIn()
          && request.resource.data.senderId == request.auth.uid
          && request.auth.uid in get(/databases/$(database)/documents/deals/$(dealId)).data.participantIds;
        allow update, delete: if false;
      }

      match /reviews/{reviewerId} {
        allow read: if isSignedIn();
        allow create: if isSelf(reviewerId)
          && request.auth.uid in get(/databases/$(database)/documents/deals/$(dealId)).data.participantIds;
        allow update, delete: if false;
      }
    }

    // Top-level reviews mirror (used for aggregate queries by revieweeId).
    match /reviews/{reviewId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.reviewerId == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
