rules_version = '2';

// Gifted Storage rules. Photo URLs are stored in Firestore; Storage access
// is scoped by owner/participant while allowing approved members to view.

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function isApprovedMember() {
      return isSignedIn()
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.status == 'approved';
    }
    function isDealParticipant(dealId) {
      return isSignedIn()
        && request.auth.uid in firestore.get(/databases/(default)/documents/deals/$(dealId)).data.participantIds;
    }
    function validImage(maxBytes) {
      return request.resource.size <= maxBytes
        && request.resource.contentType.matches('image/.*');
    }

    match /users/{uid}/profile/avatar.jpg {
      allow read: if isOwner(uid) || isApprovedMember();
      allow write: if isOwner(uid) && validImage(3 * 1024 * 1024);
      allow delete: if isOwner(uid);
    }

    match /users/{uid}/portfolio/{fileName} {
      allow read: if isOwner(uid) || isApprovedMember();
      allow write: if isOwner(uid) && validImage(6 * 1024 * 1024);
      allow delete: if isOwner(uid);
    }

    match /deals/{dealId}/photos/{uid}/{fileName} {
      allow read: if isDealParticipant(dealId) || isApprovedMember();
      allow write: if isOwner(uid)
        && isDealParticipant(dealId)
        && validImage(6 * 1024 * 1024);
      allow delete: if isOwner(uid) && isDealParticipant(dealId);
    }
  }
}
